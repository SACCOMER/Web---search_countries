<div class="container mt-5">

  <h1 class="text-center mb-4">Country Search</h1>

  <%= form_with url: countries_path, method: :get, local: true, class: "d-flex justify-content-center mb-4" do %>
    <%= text_field_tag :name, params[:name], class: "form-control w-50 me-2", placeholder: "Enter country name" %>
    <%= submit_tag "Search", class: "btn btn-primary" %>
  <% end %>

  <table class="table table-striped table-hover text-center shadow">
    <thead class="table-dark">
    <tr>
      <th>Flag</th>
      <th>Name</th>
      <th>Region</th>
      <th>Details</th>
    </tr>
    </thead>

    <tbody>
    <% @countries.each do |country| %>
      <tr>
        <td>
          <%= image_tag(country["flags"]["png"], class: "img-fluid", style: "max-width: 100px;") %>
        </td>
        <td>
          <%= country["name"]["common"] %>
        </td>
        <td>
          <%= country["region"] %>
        </td>
        <td>
          <%= link_to "View", country_path(country["name"]["common"]), class: "btn btn-sm btn-outline-primary" %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>

</div>