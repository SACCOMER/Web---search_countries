<div class="container mt-5 text-center">

  <h1 class="mb-4"><%= @country["name"]["common"] %></h1>

  <%= image_tag @country["flags"]["png"], class: "img-fluid mb-4", style: "max-width: 200px;" %>

  <div class="card p-4 shadow-sm">
    <p><strong>Capital:</strong> <%= @country["capital"]&.first %></p>
    <p><strong>Population:</strong> <%= number_with_delimiter(@country["population"]) %></p>
    <p><strong>Region:</strong> <%= @country["region"] %></p>
  </div>

  <%= link_to "Back", root_path, class: "btn btn-secondary mt-4" %>

</div>